rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper to check if user is signed in and verified
    function isVerified() {
      return request.auth != null && 
        (request.auth.token.email_verified == true || request.auth.token.email != null) && 
        (request.auth.token.email == "devmeron528@gmail.com" || 
         request.auth.token.email == "yared.abegaz@gmail.com" || 
         request.auth.token.email == "molla.yareds@gmail.com");
    }

    // Match files uploaded to user-specific directories
    match /users/{userId}/{allPaths=**} {
      allow read: if isVerified() && request.auth.uid == userId;
      allow write: if isVerified() && request.auth.uid == userId 
                     && request.resource.size < 10 * 1024 * 1024 // 10MB limit
                     && request.resource.contentType.matches('image/.*|application/pdf|text/plain|application/msword|application/vnd.openxmlformats-officedocument.wordprocessingml.document');
    }
    
    // Fallback default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
